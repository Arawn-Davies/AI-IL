{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch AIL-Runtime",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/source/AIL-Runtime/AIL-Runtime.csproj",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Attach to AIL-Runtime",
            "type": "dotnet",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}